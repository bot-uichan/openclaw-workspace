{
  "name": "dlsite-play-tui",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "TypeScript TUI client for play.dlsite.com",
  "bin": {
    "dlsite-tui": "dist/cli.js"
  },
  "scripts": {
