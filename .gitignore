# OpenClaw workspace (public-safe) .gitignore
# Safety-first defaults. Un-ignore explicitly if you intend to publish.

# --- secrets / config ---
.env
.env.*
*.key
*.pem
*.p12
*.crt
*.cer
*.der
*.pfx
secrets/
config*.json
config*.yml
config*.yaml

# --- personal memory / notes ---
MEMORY.md
memory/
TOOLS.md
# USER.md は公開対象のため除外しない

# --- logs / pids / caches ---
*.log
*.pid
*.sqlite
*.db
.cache/
tmp/
temp/

# --- downloads / generated ---
downloads/
out/
dist/
build/
coverage/

# --- node / python / misc ---
node_modules/
__pycache__/
*.pyc
.venv/
*.egg-info/

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- local workspace clutter (ignore everything not currently committed) ---
.agents/
.openclaw/
BOOTSTRAP.md
abe-top-20190328-2.jpg
akaz_motivation.png
akaz_motivation.svg
akaz_motivation_daily.json
bin/
bun-linux-x64-baseline/
mootio/
scratch/
skills/hikkaku
tmp_akaz_notes_1000.json
tmp_akaz_notes_up_to_1000.json
tmp_nostr_fetch.js
tmp_nostr_late.json
vite-react-app/
